# Admin Backend Configuration
# Copy this file to .env and fill in the values

# Database Configuration
DB_NAME=ott_platform_db
DB_USERNAME=postgres
DB_PASSWORD=ott_db_pass
DB_WRITE_HOST=database
DB_PORT=5432

# Redis Configuration
REDIS_DB_HOST=redis
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=ott_redis_pass

# Application
APP_NAME=ott-admin-service
NODE_ENV=development
PORT=8003
LOG_LEVEL=info

# JWT & Admin Authentication
JWT_SECRET=change-me-in-production
ADMIN_SECRET=change-me-in-production-admin
JWT_EXPIRY=15m
ADMIN_TOKEN_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=10

# File Upload Configuration
MAX_FILE_SIZE=104857600  # 100MB in bytes

# Database URL (for Prisma)
DATABASE_URL=postgresql://postgres:ott_db_pass@database:5432/ott_platform_db
