# User Backend Configuration
# Copy this file to .env and fill in the values

# Database Configuration
DB_NAME=ott_platform_db
DB_USERNAME=postgres
DB_PASSWORD=ott_db_pass
DB_WRITE_HOST=database
DB_PORT=5432

# Redis Configuration
REDIS_DB_HOST=redis
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=ott_redis_pass

# Application
APP_NAME=ott-user-service
NODE_ENV=development
PORT=8002
LOG_LEVEL=info

# JWT & Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=10

# Razorpay Payment Integration
# Get these from https://razorpay.com/dashboard
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=rzp_test_your_secret

# API Base URL (for frontend to connect)
NEXT_PUBLIC_API_URL=http://localhost:8002
