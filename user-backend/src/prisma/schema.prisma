// OTT Platform Database Schema (upgraded)
// PostgreSQL + Prisma — complete OTT data model

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------
// ENUMS
// -------------------------

enum UserRole {
  USER
  ADMIN
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  PAUSED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SubscriptionPlanType {
  FREE
  MONTHLY
  YEARLY
}

enum ContentType {
  SERIES
  MOVIE
  DOCUMENTARY
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  UPCOMING
  ARCHIVED
}

enum CategoryType {
  TOP_PICKS
  RECOMMENDED
  NEW_RELEASES
  UPCOMING
  TRENDING
  CUSTOM
}
enum EpisodeStatus {
  PROCESSING
  READY
  FAILED
}

enum SeriesStatus {
  DRAFT
  ACTIVE
  UPCOMING
  ARCHIVED
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// -------------------------
// MODELS
// IDs use cuid() (UUID-like) per project requirement
// -------------------------

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  avatarUrl    String?
  role         UserRole        @default(USER)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  subscription  UserSubscription?
  watchHistory  WatchHistory[]
  watchList     WatchList[]
  payments      Payment[]

  @@index([email])
}

model SubscriptionPlan {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  priceInPaise Int
  durationDays Int
  features     String[]
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  planId             String
  amountInPaise      Int
  currency           String        @default("INR")
  status             PaymentStatus @default(PENDING)
  razorpayOrderId    String?
  razorpayPaymentId  String?
  razorpaySignature  String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
}

model Series {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String?
  genres        String[]
  thumbnailUrl  String?
  bannerUrl     String?
  status        SeriesStatus   @default(DRAFT)
  releaseDate   DateTime?
  totalEpisodes Int            @default(0)
  viewCount     Int            @default(0)
  isFeatured    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  episodes      Episode[]
  categories    SeriesCategory[]

  @@index([status, viewCount, releaseDate])
}

model Episode {
  id              String        @id @default(cuid())
  seriesId        String
  title           String
  episodeNumber   Int
  description     String?
  thumbnailUrl    String?
  durationSeconds Int           @default(0)
  isFree          Boolean       @default(false)
  viewCount       Int           @default(0)
  status          EpisodeStatus @default(PROCESSING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  series   Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  videoAsset VideoAsset?
  watchHistory WatchHistory[]

  @@unique([seriesId, episodeNumber])
  @@index([seriesId, episodeNumber])
}

model VideoAsset {
  id              String      @id @default(cuid())
  episodeId       String      @unique
  originalPath    String?
  hlsDirectory    String?
  hlsManifestPath String?
  durationSeconds Int         @default(0)
  fileSizeBytes   BigInt      @default(0) @db.BigInt
  resolution      String?
  status          VideoStatus @default(PENDING)
  processingError String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}

model Category {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  description  String?
  displayOrder Int              @default(0)
  isAutomatic  Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  series SeriesCategory[]
}

model SeriesCategory {
  id           String   @id @default(cuid())
  seriesId     String
  categoryId   String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  series   Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([seriesId, categoryId])
}

model WatchHistory {
  id              String   @id @default(cuid())
  userId          String
  episodeId       String
  seriesId        String
  progressSeconds Int      @default(0)
  durationSeconds Int      @default(0)
  isCompleted     Boolean  @default(false)
  watchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  series  Series  @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model WatchList {
  id       String   @id @default(cuid())
  userId   String
  seriesId String
  addedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
}
