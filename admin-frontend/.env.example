# Admin Frontend Configuration
# Copy this file to .env.local and fill in the values
# Note: NEXT_PUBLIC_* variables are exposed to the browser

# API Configuration
# In development with Docker: http://localhost:8003
# In production: https://admin-api.ott-platform.com
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8003

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: Environment
# NEXT_PUBLIC_APP_ENV=development
