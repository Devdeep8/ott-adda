# Production Environment Configuration
# Copy this file to .env.prod and update all values for production deployment
# IMPORTANT: Never commit .env.prod with real secrets!

# Database Credentials (PostgreSQL)
DB_USER=ott_admin
DB_PASSWORD=change_this_to_strong_random_password_min_32_chars
DB_NAME=ott_platform_prod

# Redis Credentials
REDIS_PASSWORD=change_this_to_strong_random_password_min_32_chars

# JWT Secrets (generate random strings, minimum 32 characters each)
JWT_SECRET=change_this_to_random_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_to_random_jwt_refresh_secret_min_32_chars
ADMIN_SECRET=change_this_to_random_admin_secret_min_32_chars

# Application Environment
NODE_ENV=production
PORT_USER_BACKEND=8002
PORT_ADMIN_BACKEND=8003

# Razorpay Production Keys (get from https://razorpay.com/dashboard)
RAZORPAY_KEY_ID=rzp_live_your_production_live_key
RAZORPAY_KEY_SECRET=rzp_live_your_production_secret

# Domain Configuration
USER_FRONTEND_URL=https://ott-platform.com
ADMIN_FRONTEND_URL=https://admin.ott-platform.com
USER_API_URL=https://api.ott-platform.com
ADMIN_API_URL=https://admin-api.ott-platform.com

# SSL Certificates (path to files in production)
SSL_CERT_PATH=/etc/ssl/certs/ott-platform.com.crt
SSL_KEY_PATH=/etc/ssl/private/ott-platform.com.key

# Email Configuration (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@ott-platform.com
